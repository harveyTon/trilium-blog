# Trilium Notes ETAPI
TRILIUM_API_URL=https://your-trilium-instance.com
TRILIUM_TOKEN=your_etapi_token

# Blog settings
BLOG_NAME=Your Blog Name
BLOG_TITLE=Your Blog Title
DOMAIN=https://your-domain.com
ARTICLES_PER_PAGE=9
PORT=8080

# Image proxy (optional)
IMAGE_PROXY_ENABLED=false
IMAGE_PROXY_BASE_URL=


# AI summary (optional)
# AI_SUMMARY_MODE:
#   code = only keep local code summary, no AI request
#   ai   = keep code summary as fallback and async generate AI summary
AI_SUMMARY_ENABLED=false
AI_SUMMARY_PROVIDER=openai-compatible
AI_SUMMARY_BASE_URL=
AI_SUMMARY_API_KEY=
AI_SUMMARY_MODEL=
AI_SUMMARY_PROMPT=Summarize the article for a blog reader in concise Chinese.
AI_SUMMARY_MODE=code
AI_SUMMARY_CONCURRENCY=2
AI_SUMMARY_RATE_LIMIT_MS=1200
AI_SUMMARY_TIMEOUT_MS=60000
AI_SUMMARY_MAX_INPUT_CHARS=12000
AI_SUMMARY_DATABASE_PATH=./data/summaries.db